/-! ## Four-valued type and formula language -/

inductive Val4
| t | f | b | n
deriving DecidableEq, Repr

inductive Formula (P : Type)
| atom (p : P) (v : Val4) : Formula P
| not (φ : Formula P) : Formula P
| and (φ ψ : Formula P) : Formula P
| box (φ : Formula P) : Formula P
| val (φ : Formula P) (v : Val4) : Formula P

structure Model (W : Type) (P : Type) where
  R : W → W → Prop
  V : P → W → Val4

/-! ## Satisfaction relation

The `val` constructor extends satisfaction:
- `val φ t` holds iff `φ` is satisfied
- `val φ f` holds iff `φ` is not satisfied
- `val φ b` never holds at any world
- `val φ n` never holds at any world
-/

def satisfies {W P : Type} (M : Model W P) (w : W) : Formula P → Prop
| Formula.atom _p v => M.V _p w = v
| Formula.not φ => ¬ satisfies M w φ
| Formula.and φ ψ => satisfies M w φ ∧ satisfies M w ψ
| Formula.box φ => ∀ w', M.R w w' → satisfies M w' φ
| Formula.val φ Val4.t => satisfies M w φ
| Formula.val φ Val4.f => ¬ satisfies M w φ
| Formula.val _ Val4.b => False
| Formula.val _ Val4.n => False

/-! ## Atoms -/

inductive Atom | P deriving DecidableEq, Repr

/-! ## Target formula T(P)

T(P) = ¬□(v(P)=t) ∧ ¬□(v(P)=f) ∧ ¬□(v(P)=b) ∧ ¬□(v(P)=n)
-/

def target_formula : Formula Atom :=
  Formula.and
    (Formula.and
      (Formula.and
        (Formula.not (Formula.box (Formula.atom Atom.P Val4.t)))
        (Formula.not (Formula.box (Formula.atom Atom.P Val4.f))))
      (Formula.not (Formula.box (Formula.atom Atom.P Val4.b))))
    (Formula.not (Formula.box (Formula.atom Atom.P Val4.n)))

/-! ## T(T(P)): the four-fold negated-box conjunction asserting T(P) has no necessary truth value

T(T(P)) = ¬□(val(T(P)) = t) ∧ ¬□(val(T(P)) = f) ∧ ¬□(val(T(P)) = b) ∧ ¬□(val(T(P)) = n)

Uses the `val` constructor to assert things about the complex formula T(P).
-/

def target_target_formula : Formula Atom :=
  Formula.and
    (Formula.and
      (Formula.and
        (Formula.not (Formula.box (Formula.val target_formula Val4.t)))
        (Formula.not (Formula.box (Formula.val target_formula Val4.f))))
      (Formula.not (Formula.box (Formula.val target_formula Val4.b))))
    (Formula.not (Formula.box (Formula.val target_formula Val4.n)))

/-! ## K model

We use `Fin 7` with the following structure:
- `0` (w₀): the evaluation world
- `1` (w_good): has four successors with all four values, so T(P) holds here
- `2` (w_bad): has no successors, so all boxes are vacuously true and T(P) fails
- `3,4,5,6`: successors of w_good with values t, f, b, n respectively

From w₀, the accessible worlds are w_good (1) and w_bad (2).
This ensures:
- T(P) at w₀: for each value v, some successor of w₀ has V(P) ≠ v
- T(T(P)) at w₀: w_good satisfies T(P) (witness for ¬□(val(T(P))=f)),
                   w_bad does not satisfy T(P) (witness for ¬□(val(T(P))=t)),
                   both are accessible (witnesses for b and n conjuncts)
-/

def R_K (x y : Fin 7) : Prop :=
  (x = 0 ∧ (y = 1 ∨ y = 2)) ∨
  (x = 1 ∧ (y = 3 ∨ y = 4 ∨ y = 5 ∨ y = 6))

def V_K (_p : Atom) (w : Fin 7) : Val4 :=
  if w = 1 then Val4.t
  else if w = 2 then Val4.f
  else if w = 3 then Val4.t
  else if w = 4 then Val4.f
  else if w = 5 then Val4.b
  else if w = 6 then Val4.n
  else Val4.t

def M_K : Model (Fin 7) Atom :=
  { R := R_K, V := V_K }

/-! ## Theorem 1: T(P) is satisfiable at w₀ in the K model -/

theorem satisfies_K : satisfies M_K (0 : Fin 7) target_formula := by
  unfold target_formula; simp +decide [satisfies]
  unfold M_K; simp +decide [R_K, V_K]

/-! ## Theorem 2: T(T(P)) is satisfiable at w₀ in the K model -/

/-- At world 1 (w_good), T(P) holds because it has successors 3,4,5,6
    with all four values. -/
theorem satisfies_TP_at_wgood : satisfies M_K (1 : Fin 7) target_formula := by
  unfold target_formula
  simp +decide [satisfies]
  unfold M_K; simp +decide [R_K]

/-- At world 2 (w_bad), T(P) does NOT hold because it has no successors,
    so □(atom P t) is vacuously true, making ¬□(atom P t) false. -/
theorem not_satisfies_TP_at_wbad : ¬ satisfies M_K (2 : Fin 7) target_formula := by
  unfold target_formula; simp +decide [satisfies]
  simp +decide [M_K, R_K, V_K]

theorem satisfies_K_TTP : satisfies M_K (0 : Fin 7) target_target_formula := by
  unfold target_target_formula
  simp +decide [satisfies] at *
  unfold M_K; simp +decide [R_K]
  exact ⟨Or.inr not_satisfies_TP_at_wbad, Or.inl satisfies_TP_at_wgood⟩

/-! ## Theorem 3: The b and n conjuncts

`val φ b` and `val φ n` never hold at any world in any model, so the
negated-box conjuncts for b and n are trivially true (given accessible worlds exist).
-/

/-- `val φ b` is never satisfied at any world in any model. -/
theorem val_b_never {W P : Type} {M : Model W P} {w : W} {φ : Formula P} :
    ¬ satisfies M w (Formula.val φ Val4.b) :=
  Not.imp (fun a => a) fun a => a

/-- `val φ n` is never satisfied at any world in any model. -/
theorem val_n_never {W P : Type} {M : Model W P} {w : W} {φ : Formula P} :
    ¬ satisfies M w (Formula.val φ Val4.n) := by
  simp [satisfies]

/-- If `w` has at least one accessible world, then `¬□(val φ b)` holds trivially,
    because `val φ b` is never satisfied at any world. -/
theorem box_val_b_trivial {W P : Type} {M : Model W P} {w : W} {φ : Formula P}
    (h : ∃ w', M.R w w') :
    satisfies M w (Formula.not (Formula.box (Formula.val φ Val4.b))) := by
  unfold satisfies; aesop

/-- If `w` has at least one accessible world, then `¬□(val φ n)` holds trivially,
    because `val φ n` is never satisfied at any world. -/
theorem box_val_n_trivial {W P : Type} {M : Model W P} {w : W} {φ : Formula P}
