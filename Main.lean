/-! ## N-fold catuskoti operator -/

/-- The catuskoti operator T: applies the four-fold negated-box conjunction using the val constructor.
    T(φ) asserts that φ has no definite truth value across accessible worlds. -/
def T_apply (φ : Formula Atom) : Formula Atom :=
  Formula.and
    (Formula.and
      (Formula.and
        (Formula.not (Formula.box (Formula.val φ Val4.t)))
        (Formula.not (Formula.box (Formula.val φ Val4.f))))
      (Formula.not (Formula.box (Formula.val φ Val4.b))))
    (Formula.not (Formula.box (Formula.val φ Val4.n)))

/-- n-fold iteration of T. T_iter 0 is the atom for P (the base proposition).
    T_iter (n+1) = T(T_iter n), applying the catuskoti operator. -/
def T_iter : ℕ → Formula Atom
| 0 => Formula.atom Atom.P Val4.t
| (n + 1) => T_apply (T_iter n)

/-- T_apply applied to target_formula yields target_target_formula. -/
theorem T_apply_target_eq : T_apply target_formula = target_target_formula := rfl

/-! ## Disjoint union model construction

To prove satisfiability of T_apply(φ), we combine two models:
one where φ holds and one where φ fails, joining them at a fresh root world.
Satisfaction is preserved within each component, ensuring the root sees
both a world satisfying φ and one refuting it.
-/

/-- Combined model: two Kripke models joined at a fresh root world.
    The root sees exactly w₁ from M₁ and w₂ from M₂.
    Within each component, accessibility is inherited from the original model. -/
def combined_model {W₁ W₂ : Type} (M₁ : Model W₁ Atom) (M₂ : Model W₂ Atom)
    (w₁ : W₁) (w₂ : W₂) : Model (Option (W₁ ⊕ W₂)) Atom where
  R x y := match x, y with
    | none, some (Sum.inl a) => a = w₁
    | none, some (Sum.inr b) => b = w₂
    | some (Sum.inl a), some (Sum.inl b) => M₁.R a b
    | some (Sum.inr a), some (Sum.inr b) => M₂.R a b
    | _, _ => False
  V p w := match w with
    | none => Val4.t
    | some (Sum.inl a) => M₁.V p a
    | some (Sum.inr b) => M₂.V p b

/-- Satisfaction is preserved when embedding into the left component of a combined model. -/
theorem satisfies_combined_left {W₁ W₂ : Type} {M₁ : Model W₁ Atom} {M₂ : Model W₂ Atom}
    {w₁ : W₁} {w₂ : W₂} (φ : Formula Atom) (a : W₁) :
    satisfies (combined_model M₁ M₂ w₁ w₂) (some (Sum.inl a)) φ ↔ satisfies M₁ a φ := by
  induction' φ with φ ψ ihφ ihψ generalizing a;
  · rfl;
  · simp +decide [ *, satisfies ];
  · simp_all +decide [ satisfies ];
  · simp +decide [ *, satisfies ];
    constructor <;> intro h w' hw';
    · specialize h ( some ( Sum.inl w' ) ) ; aesop;
    · rcases w' with ( _ | _ | w' ) <;> simp_all +decide [ combined_model ];
  · cases ‹Val4› <;> simp_all +decide [ satisfies ]

/-- Satisfaction is preserved when embedding into the right component of a combined model. -/
theorem satisfies_combined_right {W₁ W₂ : Type} {M₁ : Model W₁ Atom} {M₂ : Model W₂ Atom}
    {w₁ : W₁} {w₂ : W₂} (φ : Formula Atom) (b : W₂) :
    satisfies (combined_model M₁ M₂ w₁ w₂) (some (Sum.inr b)) φ ↔ satisfies M₂ b φ := by
  induction' φ with _ _ _ _ _ _ _ _ ih generalizing b;
  · aesop;
  · simp_all +decide [ satisfies ];
  · simp_all +decide [ satisfies ];
  · simp_all +decide [ satisfies ];
    constructor;
    · intro h w' hw'; specialize h ( some ( Sum.inr w' ) ) ; aesop;
    · intro h w' hw'; rcases w' with ( _ | ⟨ _ | w' ⟩ ) <;> simp_all +decide [ combined_model ] ;
  · rename_i φ v ih;
    cases v <;> simp +decide [ *, satisfies ]

/-! ## Refutability of T_iter -/

/-- A model on Unit with no accessibility and V(P) = f. Used to refute formulas
    containing negated-box conjuncts. -/
def trivial_model : Model Unit Atom where
  R _ _ := False
  V _ _ := Val4.f

/-- Any T_iter n is refutable: there exists a model and world where it fails.
    For n = 0: atom P t fails when V(P) = f.
    For n ≥ 1: T_apply always contains ¬□(val _ b), which requires an accessible world,
    so it fails at any isolated world. -/
theorem T_iter_refutable (n : ℕ) :
    ∃ (W : Type) (M : Model W Atom) (w : W), ¬ satisfies M w (T_iter n) := by
  -- Use the type `Unit` for the world, as there is only one world in the trivial model.
  use Unit, trivial_model, ();
  induction' n with n ih <;> simp_all +decide [ T_iter ];
  · -- By definition of `trivial_model`, we know that `V(P) = f`.
    simp [satisfies, trivial_model];
  · unfold T_apply; simp +decide [ ih, satisfies ] ;

/-! ## Main satisfiability theorem -/

/-- If φ is both satisfiable and refutable, then T_apply(φ) is satisfiable.
    This is the key inductive step: we build a combined model with a root that sees
    one world where φ holds (refuting □(val φ f)) and one where it doesn't
    (refuting □(val φ t)). The b and n conjuncts are trivially satisfied
    since val _ b and val _ n are always false. -/
theorem T_apply_satisfiable (φ : Formula Atom)
    (hsat : ∃ (W : Type) (M : Model W Atom) (w : W), satisfies M w φ)
    (href : ∃ (W : Type) (M : Model W Atom) (w : W), ¬ satisfies M w φ) :
    ∃ (W : Type) (M : Model W Atom) (w : W), satisfies M w (T_apply φ) := by
  -- Use the Test model to satisfy T(φ).
  use Option (hsat.choose ⊕ href.choose), combined_model hsat.choose_spec.choose href.choose_spec.choose hsat.choose_spec.choose_spec.choose href.choose_spec.choose_spec.choose, none;
  -- By definition of combined_model, we need to show that the four conjuncts of T_apply φ hold at the root.
  simp [T_apply, satisfies];
  refine' ⟨ ⟨ _, _ ⟩, _ ⟩;
  · use some (Sum.inr href.choose_spec.choose_spec.choose);
    exact ⟨ by tauto, by simpa using satisfies_combined_right φ _ |>.not.mpr href.choose_spec.choose_spec.choose_spec ⟩;
  · use some (Sum.inl hsat.choose_spec.choose_spec.choose);
    exact ⟨ by tauto, by simpa using satisfies_combined_left φ _ |>.2 hsat.choose_spec.choose_spec.choose_spec ⟩;
  · exact ⟨ some ( Sum.inl hsat.choose_spec.choose_spec.choose ), by tauto ⟩

/-- **Main theorem**: For all n, Tⁿ(P) is satisfiable.
    - Base case (n = 0): atom P t is satisfied by any world where V(P) = t.
    - Inductive step: T_iter n is satisfiable (IH) and refutable (T_iter_refutable),
      so T_apply_satisfiable gives satisfiability of T_iter (n+1). -/
theorem T_iter_satisfiable : ∀ n : ℕ,
    ∃ (W : Type) (M : Model W Atom) (w : W), satisfies M w (T_iter n) := by
  intro n
  induction n with
  | zero =>
    exact ⟨Unit, ⟨fun _ _ => False, fun _ _ => Val4.t⟩, (), rfl⟩
  | succ n ih =>
    exact T_apply_satisfiable (T_iter n) ih (T_iter_refutable n)

